# =============================================================================
# Docking Studio - Single Container Dockerfile
# =============================================================================
# Combines all services into one container for simplified deployment
# Use with docker-compose.single.yml

FROM python:3.11-slim

LABEL maintainer="Docking Studio Team"
LABEL description="Docking Studio - Single Container with all services"

WORKDIR /app

# -----------------------------------------------------------------------------
# System dependencies
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    wget \
    git \
    libopenbabel-dev \
    libboost-all-dev \
    libeigen3-dev \
    libsqlite3-dev \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    fonts-liberation \
    libgomp1 \
    libpq-dev \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# Install AutoDock Vina
# -----------------------------------------------------------------------------
RUN wget -q https://github.com/ccsb-scripps/AutoDock-Vina/releases/download/v1.2.5/vina_1.2.5_linux_x86_64.tar.gz \
    && tar -xzf vina_1.2.5_linux_x86_64.tar.gz \
    && mv vina /usr/local/bin/ \
    && rm vina_1.2.5_linux_x86_64.tar.gz

# -----------------------------------------------------------------------------
# Python dependencies
# -----------------------------------------------------------------------------
COPY backend/requirements.txt .

RUN pip install --no-cache-dir --break-system-packages \
    fastapi \
    uvicorn \
    sqlalchemy \
    pydantic \
    biopython \
    numpy \
    rdkit-pypi \
    python-multipart>=0.0.22 \
    requests \
    meeko \
    vina \
    celery \
    redis \
    httpx \
    loguru \
    openai \
    anthropic \
    wheel>=0.46.2 \
    jaraco.context>=6.1.0 \
    psycopg2-binary

# -----------------------------------------------------------------------------
# Frontend build
# -----------------------------------------------------------------------------
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install

COPY frontend/ ./
RUN npm run build

# -----------------------------------------------------------------------------
# Backend code
# -----------------------------------------------------------------------------
COPY backend/ ./backend/
COPY VERSION pyproject.toml ./

# Create directories
RUN mkdir -p /app/backend/static /app/backend/storage /app/backend/uploads

# Move built frontend to static folder
RUN mv /app/dist/* /app/backend/static/ 2>/dev/null || mv /app/build/* /app/backend/static/ 2>/dev/null || true

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV STATIC_DIR=/app/backend/static

# -----------------------------------------------------------------------------
# Expose port
# -----------------------------------------------------------------------------
EXPOSE 8000

# -----------------------------------------------------------------------------
# Health check
# -----------------------------------------------------------------------------
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=5 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"

# -----------------------------------------------------------------------------
# Start
# -----------------------------------------------------------------------------
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
